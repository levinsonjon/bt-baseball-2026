{
  "rewrites": [
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/yesterday", "destination": "/web/yesterday.html" },
    { "source": "/news", "destination": "/web/news.html" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=60" }
      ]
    }
  ]
}
